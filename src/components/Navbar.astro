---
interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;
---

<header class="bg-navy-900 text-white">
  <div class="max-w-6xl mx-auto px-4 py-4">
    <nav aria-label="Main navigation" class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
      <a href="/" aria-label="Granite State Plumbing and Drain - Home" class="text-xl font-bold hover:text-navy-200">
        Granite State Plumbing & Drain
      </a>
      <ul class="flex gap-6 text-sm font-medium">
        <li>
          <a
            href="/services"
            class:list={[
              "hover:text-navy-200",
              { "text-navy-200 underline underline-offset-4": currentPath === "/services" }
            ]}
          >
            Services
          </a>
        </li>
        <li>
          <a
            href="/contact"
            class:list={[
              "hover:text-navy-200",
              { "text-navy-200 underline underline-offset-4": currentPath === "/contact" }
            ]}
          >
            Contact
          </a>
        </li>
      </ul>
    </nav>
  </div>
</header>