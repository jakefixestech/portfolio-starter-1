---
const currentYear = new Date().getFullYear();
---

<footer class="bg-navy-900 text-white mt-16">
  <div class="max-w-6xl mx-auto px-4 py-10">
    <div class="flex flex-col md:flex-row md:justify-between gap-6 mb-8">
      <div>
        <a href="/" class="font-bold text-lg hover:text-navy-200 transition-colors">
          Granite State Plumbing & Drain
        </a>
        <p class="text-navy-200 text-sm mt-1">Littleton, NH</p>
      </div>
      <div class="text-sm text-navy-200">
        <p>(603) 555-0100</p>
        <p>granite@example.com</p>
      </div>
      <div class="text-sm text-navy-200">
        <p>Mon–Fri: 7am–5pm</p>
        <p>Sat: 8am–12pm</p>
        <p>Sun: Closed</p>
      </div>
    </div>
    <nav aria-label="Footer navigation">
      <ul class="flex flex-wrap gap-6 mb-6">
        <li><a href="/" class="text-sm text-navy-200 hover:text-white transition-colors">Home</a></li>
        <li><a href="/services" class="text-sm text-navy-200 hover:text-white transition-colors">Services</a></li>
        <li><a href="/contact" class="text-sm text-navy-200 hover:text-white transition-colors">Contact</a></li>
      </ul>
    </nav>
    <div class="border-t border-navy-700 pt-6 text-center text-sm text-navy-300">
      <p>&copy; {currentYear} Granite State Plumbing & Drain. All rights reserved.</p>
    </div>
  </div>
</footer>