---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = 'Jake Fixes Tech — Computer Repair & Tech Services in Littleton, NH',
  description = 'Affordable, honest computer repair, tech support and website design serving Littleton, NH and the North Country. Call or text (802) 234-1552.',
  image = '/og-image.png'
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, 'https://jakefixestech.com');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Jake Charland — Jake Fixes Tech LLC" />
    <meta name="keywords" content="computer repair Littleton NH, tech support North Country, laptop repair New Hampshire, virus removal NH, data recovery NH, website design Littleton NH" />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph (Facebook, LinkedIn sharing) -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:site_name" content="Jake Fixes Tech" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />

    <!-- Local Business Schema (helps Google understand you're a local business) -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "LocalBusiness",
        "name": "Jake Fixes Tech LLC",
        "description": "Affordable computer repair, tech support and website design serving Littleton NH and the North Country.",
        "url": "https://jakefixestech.com",
        "telephone": "+18022341552",
        "email": "jake@jakefixestech.com",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "28 Groves Street Apt 1",
          "addressLocality": "Littleton",
          "addressRegion": "NH",
          "postalCode": "03561",
          "addressCountry": "US"
        },
        "geo": {
          "@type": "GeoCoordinates",
          "latitude": 44.3045,
          "longitude": -71.7745
        },
        "openingHoursSpecification": [
          {
            "@type": "OpeningHoursSpecification",
            "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
            "opens": "17:00",
            "closes": "19:30"
          },
          {
            "@type": "OpeningHoursSpecification",
            "dayOfWeek": ["Saturday", "Sunday"],
            "opens": "09:00",
            "closes": "16:00"
          }
        ],
        "priceRange": "$$",
        "areaServed": "Littleton NH and surrounding areas"
      }
    </script>

  </head>
  <body>
    <Navbar />
    <slot />
    <Footer />
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>