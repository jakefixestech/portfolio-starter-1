---
import Layout from '../layouts/Layout.astro';

const services = [
  {
    title: "Drain Cleaning",
    description: "Clogged drains slowing you down? We clear blockages fast using professional equipment to restore full flow.",
    icon: `<svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />
    </svg>`
  },
  {
    title: "Water Heater Repair",
    description: "No hot water? We diagnose and repair all types of water heaters to get your home comfortable again.",
    icon: `<svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z" />
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.879 16.121A3 3 0 1012.015 11L11 14H9c0 .768.293 1.536.879 2.121z" />
    </svg>`
  },
  {
    title: "Leak Detection",
    description: "Hidden leaks waste water and cause damage. Our detection services find leaks quickly to prevent costly repairs.",
    icon: `<svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
    </svg>`
  },
  {
    title: "Pipe Repair",
    description: "From minor fixes to major repairs, we handle burst pipes, corrosion, and damage with lasting solutions.",
    icon: `<svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
    </svg>`
  },
  {
    title: "Fixture Installation",
    description: "Upgrading your bathroom or kitchen? We install faucets, sinks, toilets, and more with precision.",
    icon: `<svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
    </svg>`
  },
  {
    title: "Emergency Plumbing",
    description: "Plumbing emergencies don't wait, and neither do we. Call us for urgent repairs when you need help fast.",
    icon: `<svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
    </svg>`
  }
];
---

<Layout title="Services">
  <!-- Page Header -->
  <section
    class="relative text-white"
    style="background-image: url('/tools.jpeg'); background-size: cover; background-position: center; background-color: rgb(16, 42, 67);"
  >
    <div class="absolute inset-0 bg-navy-900/80"></div>
    <div class="relative max-w-6xl mx-auto px-4 py-20 text-center">
      <h1 class="text-3xl md:text-4xl font-bold">Our Services</h1>
      <p class="mt-2 text-navy-200">
        Professional plumbing solutions for homes and businesses in the North Country.
      </p>
    </div>
  </section>

  <!-- Services Grid -->
  <section class="py-16">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {services.map((service) => (
          <div class="border border-navy-200 rounded-lg p-6 hover:border-navy-400">
            <div class="text-navy-900" set:html={service.icon} />
            <h2 class="mt-4 text-xl font-semibold text-navy-900">{service.title}</h2>
            <p class="mt-2 text-navy-600 text-sm leading-relaxed">{service.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="bg-navy-50 py-12">
    <div class="max-w-6xl mx-auto px-4 text-center">
      <h2 class="text-xl md:text-2xl font-bold text-navy-900">
        Don't See What You Need?
      </h2>
      <p class="mt-2 text-navy-600">
        We handle a wide range of plumbing jobs. Give us a call to discuss your project.
      </p>
      <div class="mt-6 flex flex-col sm:flex-row gap-4 justify-center">
        <a 
          href="tel:6035550100" 
          class="inline-block px-6 py-3 bg-navy-900 text-white font-semibold rounded hover:bg-navy-800"
        >
          Call (603) 555-0100
        </a>
        <a 
          href="/contact" 
          class="inline-block px-6 py-3 border-2 border-navy-900 text-navy-900 font-semibold rounded hover:bg-navy-900 hover:text-white"
        >
          Request a Quote
        </a>
      </div>
    </div>
  </section>
</Layout>