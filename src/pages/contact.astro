---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact">
  <!-- Page Header -->
  <section class="bg-navy-900 text-white py-12">
    <div class="max-w-6xl mx-auto px-4 text-center">
      <h1 class="text-3xl md:text-4xl font-bold">Contact Us</h1>
      <p class="mt-2 text-navy-200">
        Get in touch for a free estimate or to schedule service.
      </p>
    </div>
  </section>

  <!-- Contact Content -->
  <section class="py-16">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        
        <!-- Contact Information -->
        <div>
          <h2 class="text-2xl font-bold text-navy-900">Granite State Plumbing & Drain</h2>
          <p class="mt-2 text-navy-600">Littleton, NH & the North Country</p>

          <div class="mt-8 space-y-6">
            <!-- Phone -->
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-navy-100 rounded-full flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-navy-900" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
              </div>
              <div>
                <p class="font-semibold text-navy-900">Phone</p>
                <a href="tel:6035550100" class="text-navy-600 hover:text-navy-900">(603) 555-0100</a>
              </div>
            </div>

            <!-- Email -->
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-navy-100 rounded-full flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-navy-900" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <div>
                <p class="font-semibold text-navy-900">Email</p>
                <a href="mailto:granite@example.com" class="text-navy-600 hover:text-navy-900">granite@example.com</a>
              </div>
            </div>

            <!-- Hours -->
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-navy-100 rounded-full flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-navy-900" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <div>
                <p class="font-semibold text-navy-900">Business Hours</p>
                <div class="text-navy-600 text-sm mt-1 space-y-1">
                  <p>Monday – Friday: 7:00 AM – 5:00 PM</p>
                  <p>Saturday: 8:00 AM – 12:00 PM</p>
                  <p>Sunday: Closed</p>
                </div>
              </div>
            </div>
          </div>

          <div class="mt-8 p-4 bg-navy-50 rounded-lg">
            <p class="text-sm text-navy-700">
              <strong>Emergency Service:</strong> For after-hours emergencies, call our main number and leave a message. We'll get back to you as soon as possible.
            </p>
          </div>
        </div>

        <!-- Contact Form -->
        <div>
          <div class="bg-white border border-navy-200 rounded-lg p-6 md:p-8">
            <h3 class="text-xl font-bold text-navy-900">Send Us a Message</h3>
            <p class="mt-1 text-sm text-navy-600">We'll get back to you within one business day.</p>

            <form class="mt-6 space-y-5">
              <div>
                <label for="name" class="block text-sm font-medium text-navy-900">
                  Name <span class="text-red-600">*</span>
                </label>
                <input 
                  type="text" 
                  id="name" 
                  name="name" 
                  required
                  class="mt-1 w-full px-4 py-2 border border-navy-300 rounded focus:outline-none focus:ring-2 focus:ring-navy-500 focus:border-navy-500"
                  placeholder="Your name"
                />
              </div>

              <div>
                <label for="phone" class="block text-sm font-medium text-navy-900">
                  Phone <span class="text-red-600">*</span>
                </label>
                <input 
                  type="tel" 
                  id="phone" 
                  name="phone" 
                  required
                  class="mt-1 w-full px-4 py-2 border border-navy-300 rounded focus:outline-none focus:ring-2 focus:ring-navy-500 focus:border-navy-500"
                  placeholder="(603) 555-0000"
                />
              </div>

              <div>
                <label for="message" class="block text-sm font-medium text-navy-900">
                  Message <span class="text-red-600">*</span>
                </label>
                <textarea 
                  id="message" 
                  name="message" 
                  rows="4" 
                  required
                  class="mt-1 w-full px-4 py-2 border border-navy-300 rounded focus:outline-none focus:ring-2 focus:ring-navy-500 focus:border-navy-500 resize-none"
                  placeholder="Tell us about your plumbing needs..."
                ></textarea>
              </div>

              <button 
                type="submit" 
                class="w-full px-6 py-3 bg-navy-900 text-white font-semibold rounded hover:bg-navy-800 focus:outline-none focus:ring-2 focus:ring-navy-500 focus:ring-offset-2"
              >
                Send Message
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
